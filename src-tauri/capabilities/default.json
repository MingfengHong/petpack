{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the PetPack studio and pet runtime windows",
  "windows": ["studio", "pet", "pet-preview"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-always-on-top",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "opener:default"
  ]
}
